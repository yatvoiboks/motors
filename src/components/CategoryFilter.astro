---
interface Props {
  categories: { id: string; name: string; slug: string }[];
  activeCategory: string;
  clientFilter?: boolean;
}

const { categories, activeCategory, clientFilter = false } = Astro.props;
const baseUrl = '/catalog';
---

<div class="flex flex-wrap gap-2" data-category-filter>
  {categories.map((cat) => {
    const isActive = activeCategory === cat.id;
    const href = cat.id === 'all' ? baseUrl : `${baseUrl}/${cat.slug}`;
    const baseClass = `px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
      isActive
        ? 'bg-accent text-white'
        : 'bg-white text-slate-600 border border-slate-200 hover:border-accent hover:text-accent'
    }`;
    if (clientFilter) {
      return (
        <button
          type="button"
          data-category-id={cat.id}
          class={baseClass}
        >
          {cat.name}
        </button>
      );
    }
    return (
      <a href={href} class={baseClass}>
        {cat.name}
      </a>
    );
  })}
</div>
