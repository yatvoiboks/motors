---
interface Drawing {
  label: string;
  key: string;
  type: 'pdf' | 'cad';
}

interface Props {
  id: string;
  name: string;
  image: string;
  images?: string[];
  description: string;
  category: string;
  specs?: Record<string, string>;
  drawings?: Drawing[];
}

const { id, name, image, images = [], description, category, specs = {}, drawings = [] } = Astro.props;
const shortDesc = description.length > 90 ? description.slice(0, 90) + '…' : description;
const specEntries = Object.entries(specs);
const galleryImages = images.length > 0 ? images : [image];

const R2_BASE = import.meta.env.R2_BASE_URL ?? '';
function drawingUrl(key: string) {
  return R2_BASE ? `${R2_BASE}/${id}/drawings/${key}` : '#';
}
---

<article class="card">

  <!-- Photo -->
  <a href={`/product/${id}`} class="card-photo" aria-label={name}>
    <img
      src={galleryImages[0]}
      alt={name}
      width="400" height="400"
      loading="lazy" decoding="async"
      class="photo-img"
      data-gallery-images={JSON.stringify(galleryImages)}
    />
    {galleryImages.length > 1 && (
      <div class="photo-dots" aria-hidden="true">
        {galleryImages.map((_, i) => (
          <span class={`dot${i === 0 ? ' active' : ''}`} data-dot={i}></span>
        ))}
      </div>
    )}
  </a>

  <!-- Body -->
  <div class="card-body">
    <div class="card-top">
      <span class="cat">{category}</span>
    </div>
    <a href={`/product/${id}`} class="card-name">{name}</a>
    <p class="card-desc">{shortDesc}</p>

    {specEntries.length > 0 && (
      <dl class="specs">
        {specEntries.map(([k, v]) => (
          <>
            <dt>{k}</dt>
            <dd>{v}</dd>
          </>
        ))}
      </dl>
    )}
  </div>

  <!-- Drawings section -->
  {drawings.length > 0 && (
    <div class="drawings-section">
      <button class="drawings-toggle" type="button" aria-expanded="false">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="11" height="11" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
          <line x1="3.5" y1="4" x2="9.5" y2="4" stroke="currentColor" stroke-width="1.1"/>
          <line x1="3.5" y1="6.5" x2="9.5" y2="6.5" stroke="currentColor" stroke-width="1.1"/>
          <line x1="3.5" y1="9" x2="6.5" y2="9" stroke="currentColor" stroke-width="1.1"/>
        </svg>
        Technical Drawings
        <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="drawings-list" hidden>
        {drawings.map((d) => (
          <a
            href={drawingUrl(d.key)}
            class="drawing-row"
            download
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class={`dtype dtype-${d.type}`}>{d.type === 'pdf' ? 'PDF' : 'CAD'}</span>
            <span class="dlabel">{d.label}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="dl-icon" aria-hidden="true">
              <path d="M6 2v6M3.5 6l2.5 2.5L8.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="2" y1="10.5" x2="10" y2="10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="card-footer">
    <a href={`/product/${id}`} class="btn btn-outline btn-sm">Details</a>
    <a href="/contact" class="btn btn-primary btn-sm">Request Quote</a>
  </div>
</article>

<script>
  // Drawings toggle
  document.querySelectorAll<HTMLButtonElement>('.drawings-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      const list = btn.nextElementSibling as HTMLElement;
      open ? list.setAttribute('hidden', '') : list.removeAttribute('hidden');
      btn.querySelector<SVGElement>('.chevron')!.style.transform = open ? '' : 'rotate(180deg)';
    });
  });
</script>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* Photo */
  .card-photo {
    display: block; position: relative;
    aspect-ratio: 1; background: var(--bg-2);
    overflow: hidden; text-decoration: none;
  }
  .photo-img {
    width: 100%; height: 100%;
    object-fit: contain; object-position: center;
    padding: 16px;
    transition: transform 0.3s;
  }
  .card:hover .photo-img { transform: scale(1.04); }

  .photo-dots {
    position: absolute; bottom: 8px; left: 0; right: 0;
    display: flex; justify-content: center; gap: 5px;
  }
  .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--t3); display: block;
    transition: background 0.15s;
  }
  .dot.active { background: var(--accent); }

  /* Body */
  .card-body { padding: 14px 16px; flex: 1; }
  .card-top { margin-bottom: 6px; }
  .cat {
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent);
  }
  .card-name {
    display: block; font-size: 14px; font-weight: 700;
    color: var(--t1); text-decoration: none;
    margin-bottom: 6px; line-height: 1.3;
    transition: color 0.15s;
  }
  .card-name:hover { color: var(--accent); }
  .card-desc { font-size: 12px; color: var(--t3); line-height: 1.6; margin-bottom: 12px; }

  /* Specs */
  .specs {
    display: grid; grid-template-columns: auto 1fr;
    gap: 2px 14px; font-family: var(--mono); font-size: 11px;
  }
  .specs dt { color: var(--t3); white-space: nowrap; }
  .specs dd { color: var(--accent-h); font-weight: 500; }

  /* Drawings */
  .drawings-section { border-top: 1px solid var(--border); }
  .drawings-toggle {
    width: 100%; padding: 9px 16px;
    display: flex; align-items: center; gap: 7px;
    background: none; border: none; cursor: pointer;
    font-family: var(--font); font-size: 12px; font-weight: 600;
    color: var(--t2); text-align: left; transition: color 0.15s;
  }
  .drawings-toggle:hover { color: var(--t1); }
  .drawings-toggle > svg:first-child { color: var(--accent); flex-shrink: 0; }
  .chevron { margin-left: auto; color: var(--t3); transition: transform 0.2s; flex-shrink: 0; }

  .drawings-list { padding: 0 12px 10px; display: flex; flex-direction: column; gap: 4px; }
  .drawing-row {
    display: flex; align-items: center; gap: 7px;
    padding: 6px 10px; border-radius: var(--r);
    background: var(--bg-2); border: 1px solid var(--border);
    text-decoration: none; color: var(--t2);
    font-size: 11px; font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
  }
  .drawing-row:hover { border-color: var(--accent); color: var(--t1); }
  .dtype {
    font-size: 9px; font-weight: 700; letter-spacing: 0.05em;
    padding: 2px 5px; border-radius: 3px; flex-shrink: 0;
  }
  .dtype-pdf { background: rgba(220,50,50,0.15); color: #e07070; border: 1px solid rgba(220,50,50,0.2); }
  .dtype-cad { background: var(--accent-t); color: var(--accent-h); border: 1px solid rgba(58,143,232,0.2); }
  .dlabel { flex: 1; }
  .dl-icon { color: var(--t3); flex-shrink: 0; }
  .drawing-row:hover .dl-icon { color: var(--accent); }

  /* Footer */
  .card-footer {
    padding: 10px 16px; border-top: 1px solid var(--border);
    display: flex; gap: 8px; justify-content: flex-end;
  }
</style>
