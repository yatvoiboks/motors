---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  cta?: boolean;
}
const { title, subtitle, label = 'Industrial UAV Components', cta = false } = Astro.props;
---

<section class="hero">
  <div class="container">
    <div class="section-label">{label}</div>
    <h1 set:html={title} />
    {subtitle && <p class="sub">{subtitle}</p>}
    {cta && (
      <div class="actions">
        <a href="/catalog" class="btn btn-primary">View Catalog</a>
        <a href="/contact" class="btn btn-outline">Request Quote</a>
      </div>
    )}
  </div>
  <div class="glow" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative; overflow: hidden;
    padding: 88px 0 72px;
    border-bottom: 1px solid var(--border);
  }
  .hero h1 { margin: 8px 0 20px; }
  .hero h1 :global(.accent) { color: var(--accent); }
  .sub {
    font-size: 16px; color: var(--t2);
    max-width: 560px; line-height: 1.7;
  }
  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px; }
  .glow {
    position: absolute; top: -100px; right: -100px;
    width: 700px; height: 700px; pointer-events: none;
    background: radial-gradient(circle, rgba(58,143,232,0.07) 0%, transparent 65%);
  }
</style>
