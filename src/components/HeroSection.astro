---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<section class="bg-primary text-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight">{title}</h1>
      {subtitle && <p class="mt-4 text-xl text-slate-300">{subtitle}</p>}
    </div>
  </div>
</section>
