---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const featured = products.slice(0, 6);
---

<BaseLayout
  title="GlobalRobotex — UAV Components"
  description="B2B manufacturer of high-precision propulsion components for industrial UAV systems: motors, ESCs, propellers."
>
  <Navbar />
  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-layout">

        <!-- Left: text -->
        <div class="hero-text">
          <div class="section-label">Industrial UAV Components</div>
          <h1>Propulsion Systems<br>for Industrial <span class="accent">UAV</span></h1>
          <p class="hero-sub">
            High-precision motors, ESCs and propellers for industrial multirotor platforms.
            B2B supply · OEM partnerships · technical documentation included.
          </p>
          <div class="hero-actions">
            <a href="/catalog" class="btn btn-primary">View Catalog</a>
            <a href="/contact" class="btn btn-outline">Request Quote</a>
          </div>
          <div class="hero-stats">
            <div class="stat"><span class="sv">40+</span><span class="sl">SKUs in stock</span></div>
            <div class="sdiv"></div>
            <div class="stat"><span class="sv">6–14S</span><span class="sl">Voltage range</span></div>
            <div class="sdiv"></div>
            <div class="stat"><span class="sv">OEM</span><span class="sl">Custom orders</span></div>
          </div>
        </div>

        <!-- Right: motor schematic -->
        <div class="hero-visual" aria-hidden="true">
          <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="motor-svg">
            <!-- Outer ring -->
            <circle cx="200" cy="200" r="160" stroke="#1A2D4A" stroke-width="1"/>
            <circle cx="200" cy="200" r="160" stroke="#3A8FE8" stroke-width="1.5" stroke-dasharray="6 10" opacity="0.4"/>
            <!-- Mid ring -->
            <circle cx="200" cy="200" r="110" stroke="#1A2D4A" stroke-width="1"/>
            <circle cx="200" cy="200" r="110" stroke="#3A8FE8" stroke-width="1" opacity="0.25"/>
            <!-- Stator body -->
            <circle cx="200" cy="200" r="72" fill="#111E36" stroke="#1A2D4A" stroke-width="1.5"/>
            <circle cx="200" cy="200" r="72" stroke="#3A8FE8" stroke-width="1" opacity="0.5"/>
            <!-- Stator slots (12 poles) -->
            {Array.from({length: 12}, (_, i) => {
              const angle = (i * 30) * Math.PI / 180;
              const x1 = (200 + 72 * Math.cos(angle)).toFixed(1);
              const y1 = (200 + 72 * Math.sin(angle)).toFixed(1);
              const x2 = (200 + 110 * Math.cos(angle)).toFixed(1);
              const y2 = (200 + 110 * Math.sin(angle)).toFixed(1);
              return (
                <g>
                  <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#1A2D4A" stroke-width="8"/>
                  <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#3A8FE8" stroke-width="1" opacity="0.6"/>
                </g>
              );
            })}
            <!-- Shaft -->
            <circle cx="200" cy="200" r="18" fill="#0B1527" stroke="#3A8FE8" stroke-width="1.5"/>
            <circle cx="200" cy="200" r="6" fill="#3A8FE8" opacity="0.8"/>
            <!-- Cross hairs -->
            <line x1="200" y1="40" x2="200" y2="360" stroke="#1A2D4A" stroke-width="1" stroke-dasharray="3 8"/>
            <line x1="40"  y1="200" x2="360" y2="200" stroke="#1A2D4A" stroke-width="1" stroke-dasharray="3 8"/>
            <!-- Dimension arrows -->
            <line x1="200" y1="22" x2="360" y2="22" stroke="#4A5F7A" stroke-width="1"/>
            <text x="280" y="17" fill="#4A5F7A" font-family="'Courier New',monospace" font-size="11" text-anchor="middle">Ø 320 mm</text>
            <!-- Labels -->
            <text x="200" y="290" fill="#3A8FE8" font-family="'Courier New',monospace" font-size="10" text-anchor="middle" opacity="0.7">STATOR 100×22</text>
            <text x="200" y="305" fill="#4A5F7A" font-family="'Courier New',monospace" font-size="9" text-anchor="middle">12N14P · KV 110</text>
            <!-- Corner marks -->
            <path d="M30 30 L30 50 M30 30 L50 30" stroke="#1A2D4A" stroke-width="1.5"/>
            <path d="M370 30 L370 50 M370 30 L350 30" stroke="#1A2D4A" stroke-width="1.5"/>
            <path d="M30 370 L30 350 M30 370 L50 370" stroke="#1A2D4A" stroke-width="1.5"/>
            <path d="M370 370 L370 350 M370 370 L350 370" stroke="#1A2D4A" stroke-width="1.5"/>
          </svg>
        </div>

      </div>
      <div class="glow" aria-hidden="true"></div>
    </section>

    <!-- FEATURED PRODUCTS -->
    <section class="catalog-section">
      <div class="container">
        <div class="section-label">Products</div>
        <h2>Featured Components</h2>

        <div class="product-grid">
          {featured.map((p) => (
            <ProductCard
              id={p.id}
              name={p.name}
              image={p.image}
              images={p.images}
              description={p.description}
              category={p.category}
              specs={p.specs}
              drawings={p.drawings}
            />
          ))}
        </div>

        <div class="catalog-cta">
          <a href="/catalog" class="btn btn-outline">
            View Full Catalog
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="values-section">
      <div class="container">
        <div class="values-grid">
          <div class="value-card">
            <div class="vc-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2L12.5 7.5H18L13.5 11L15.5 17L10 13.5L4.5 17L6.5 11L2 7.5H7.5L10 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="vc-title">Precision</div>
            <div class="vc-desc">Specifications are measured values — the primary technical argument</div>
          </div>
          <div class="value-card">
            <div class="vc-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"/>
                <path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="vc-title">Reliability</div>
            <div class="vc-desc">Industrial-grade quality control on every production batch</div>
          </div>
          <div class="value-card">
            <div class="vc-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="3" y="4" width="14" height="12" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="6" y1="11" x2="14" y2="11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="6" y1="14" x2="10" y2="14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="vc-title">Documentation</div>
            <div class="vc-desc">CAD models and dimensional drawings included with every order</div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative; overflow: hidden;
    padding: 88px 0 72px;
    border-bottom: 1px solid var(--border);
  }
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 48px;
    align-items: center;
  }
  .accent { color: var(--accent); }
  .hero h1 { margin: 8px 0 20px; }
  .hero-sub {
    font-size: 16px; color: var(--t2);
    max-width: 480px; line-height: 1.7; margin-bottom: 32px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 48px; }
  .hero-stats { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .sv { font-size: 22px; font-weight: 700; color: var(--t1); letter-spacing: -0.01em; }
  .sl { font-size: 11px; color: var(--t3); text-transform: uppercase; letter-spacing: 0.1em; }
  .sdiv { width: 1px; height: 36px; background: var(--border); }

  .hero-visual {
    display: flex; align-items: center; justify-content: center;
    opacity: 0.85;
  }
  .motor-svg {
    width: 100%; max-width: 380px;
    filter: drop-shadow(0 0 40px rgba(58,143,232,0.12));
  }

  .glow {
    position: absolute; top: -100px; right: -100px;
    width: 700px; height: 700px; pointer-events: none;
    background: radial-gradient(circle, rgba(58,143,232,0.07) 0%, transparent 65%);
  }

  /* CATALOG */
  .catalog-section { padding: 72px 0; }
  .catalog-section h2 { margin-bottom: 36px; }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .catalog-cta { text-align: center; }

  /* VALUES */
  .values-section {
    padding: 64px 0;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
  }
  .values-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .value-card {
    padding: 24px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--r-lg);
  }
  .vc-icon {
    width: 40px; height: 40px; border-radius: var(--r);
    background: var(--accent-t); border: 1px solid rgba(58,143,232,0.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); margin-bottom: 16px;
  }
  .vc-title { font-size: 14px; font-weight: 700; color: var(--t1); margin-bottom: 6px; }
  .vc-desc { font-size: 13px; color: var(--t3); line-height: 1.6; }

  @media (max-width: 1100px) {
    .hero-layout { grid-template-columns: 1fr 320px; gap: 32px; }
  }
  @media (max-width: 860px) {
    .hero-layout { grid-template-columns: 1fr; }
    .hero-visual  { display: none; }
  }
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .product-grid { grid-template-columns: 1fr; }
    .values-grid  { grid-template-columns: 1fr; }
    .hero { padding: 60px 0 48px; }
  }
</style>
