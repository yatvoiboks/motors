---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecTable from '../../components/SpecTable.astro';
import products from '../../data/products.json';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const quoteSubject = encodeURIComponent(`Quote request: ${product.name}`);
const mailtoUrl = `mailto:sales@globalrobotex.com?subject=${quoteSubject}`;
const R2_BASE = import.meta.env.R2_BASE_URL ?? '';
function drawingUrl(key: string) {
  return R2_BASE ? `${R2_BASE}/${product.id}/drawings/${key}` : '#';
}
---

<BaseLayout
  title={`${product.name} | GlobalRobotex`}
  description={product.description}
  image={product.image}
>
  <Navbar />
  <main class="product-page">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/catalog">Catalog</a>
        <span>/</span>
        <span class="bc-current">{product.name}</span>
      </nav>

      <!-- Product layout -->
      <div class="product-layout">

        <!-- Gallery -->
        <div>
          <ProductGallery name={product.name} image={product.image} images={product.images} model3d={product.model3d} />
        </div>

        <!-- Details -->
        <div class="product-details">
          <span class="prod-cat">{product.category}</span>
          <h1 class="prod-name">{product.name}</h1>
          <p class="prod-desc">{product.description}</p>

          <!-- Specs -->
          <div class="detail-block">
            <h2 class="block-title">Specifications</h2>
            <SpecTable specs={product.specs} />
          </div>

          <!-- Drawings -->
          {product.drawings && product.drawings.length > 0 && (
            <div class="detail-block drawings-block">
              <h2 class="block-title">Technical Drawings</h2>
              <div class="drawings-list">
                {product.drawings.map((d) => (
                  <a
                    href={drawingUrl(d.key)}
                    class="drawing-row"
                    download
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class={`dtype dtype-${d.type}`}>
                      {d.type === 'pdf' ? 'PDF' : 'CAD'}
                    </span>
                    <span class="dlabel">{d.label}</span>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="dl-icon" aria-hidden="true">
                      <path d="M7 2v7M4 7l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      <line x1="2" y1="12" x2="12" y2="12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- CTA -->
          <a href={mailtoUrl} class="btn btn-primary cta-btn">
            Request Quote
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 4l6 4 6-4M2 4h12v9H2z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .product-page { padding: 16px 0 80px; }

  /* Full-width layout on desktop */
  @media (min-width: 1100px) {
    .product-page .container {
      max-width: 100%;
      padding: 0 64px;
    }
  }

  .breadcrumb {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--t3);
    margin-bottom: 24px;
  }
  .breadcrumb a { color: var(--t3); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .bc-current { color: var(--t1); font-weight: 500; }

  .product-layout {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: 48px;
    align-items: start;
  }

  /* Description left, gallery right */
  .product-layout > div:first-child { order: 2; }
  .product-layout > .product-details { order: 1; }

  .prod-cat {
    display: block;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 8px;
  }
  .prod-name {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800; letter-spacing: -0.02em; line-height: 1.15;
    margin-bottom: 16px; color: var(--t1);
  }
  .prod-desc {
    font-size: 15px; color: var(--t2);
    line-height: 1.75; margin-bottom: 32px;
  }

  .detail-block { margin-bottom: 32px; }
  .block-title {
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--t3); margin-bottom: 12px;
  }

  /* Drawings list */
  .drawings-list { display: flex; flex-direction: column; gap: 6px; }
  .drawing-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: var(--r);
    background: var(--bg-card); border: 1px solid var(--border);
    text-decoration: none; color: var(--t2);
    font-size: 13px; font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
  }
  .drawing-row:hover { border-color: var(--accent); color: var(--t1); }
  .dtype {
    font-size: 9px; font-weight: 700; letter-spacing: 0.05em;
    padding: 2px 6px; border-radius: 3px; flex-shrink: 0;
  }
  .dtype-pdf { background: rgba(220,50,50,0.15); color: #e07070; border: 1px solid rgba(220,50,50,0.2); }
  .dtype-cad { background: var(--accent-t); color: var(--accent-h); border: 1px solid rgba(58,143,232,0.2); }
  .dlabel { flex: 1; }
  .dl-icon { color: var(--t3); flex-shrink: 0; }
  .drawing-row:hover .dl-icon { color: var(--accent); }

  .cta-btn { margin-top: 8px; padding: 13px 28px; font-size: 15px; }

  @media (max-width: 900px) {
    .product-layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
